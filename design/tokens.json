{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Mission Control dashboard tokens. Marketing reference: 00-unimarketingagency/design/tokens.json (adapted for light interactive UI).",
  "color": {
    "bg": {
      "primary": { "$value": "#f8fafc", "$type": "color" },
      "dark": { "$value": "#060c16", "$type": "color", "$description": "Dark theme page bg (matches marketing site)" }
    },
    "surface": {
      "card": { "$value": "#ffffff", "$type": "color" },
      "dark": { "$value": "#0d1117", "$type": "color" }
    },
    "accent": {
      "default": { "$value": "#E85D04", "$type": "color", "$description": "UNI brand — data-accent=uni" }
    },
    "text": {
      "primary": { "$value": "#1e293b", "$type": "color" },
      "muted": { "$value": "#64748b", "$type": "color" }
    },
    "border": {
      "default": { "$value": "#e2e8f0", "$type": "color" }
    }
  },
  "font": {
    "display": { "$value": "Syne, system-ui, sans-serif", "$type": "fontFamily" },
    "body": { "$value": "Inter, system-ui, sans-serif", "$type": "fontFamily" },
    "mono": { "$value": "DM Mono, ui-monospace, monospace", "$type": "fontFamily" }
  },
  "spacing": {
    "tab-page-gap": { "$value": "24px", "$type": "dimension", "$description": "comfort density vertical stack" },
    "tab-page-gap-compact": { "$value": "12px", "$type": "dimension" },
    "section-pad": { "$value": "16px", "$type": "dimension" },
    "table-cell-x": { "$value": "12px", "$type": "dimension" },
    "table-cell-y": { "$value": "10px", "$type": "dimension" }
  },
  "component": {
    "table-min-width-default": { "$value": "640px", "$type": "dimension" },
    "filter-sticky-top": { "$value": "5.5rem", "$type": "dimension" }
  }
}
