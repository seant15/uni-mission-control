# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# Required for /api/chat to persist assistant replies (Vercel serverless — do not prefix with VITE_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenRouter (required for UNI AI Assistant widget — set on Vercel Production + Preview)
OPENROUTER_API_KEY=your-openrouter-api-key-here
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Optional: OpenClaw Control UI in iframe — see docs/OPENCLAW_CHAT_URL.md
# Option A — full URL (official: put gateway token in the fragment, not query):
#   VITE_OPENCLAW_CHAT_URL=https://your-gateway.example.com/#token=your-gateway-token
# Option B — base + token (app builds …/#token=…; token must match gateway.auth.token exactly, no extra quotes):
#   VITE_OPENCLAW_GATEWAY_BASE=https://your-gateway.example.com
#   VITE_OPENCLAW_GATEWAY_TOKEN=your-gateway-token
# If you see "gateway token mismatch", regenerate on the gateway host and redeploy env, or paste the full `openclaw dashboard --no-open` URL into VITE_OPENCLAW_CHAT_URL instead.
# VITE_OPENCLAW_CHAT_URL=https://...
